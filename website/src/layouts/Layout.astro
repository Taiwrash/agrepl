---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Deterministic Replay for AI Agents" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="bg-glow"></div>
		<nav>
			<div class="container">
				<a href={import.meta.env.BASE_URL} class="logo">
					<span class="logo-icon"></span>
					agrepl
				</a>
				<div class="links">
					<a href={`${import.meta.env.BASE_URL}/docs/introduction`}>Docs</a>
					<a href="https://github.com/taiwrash/agrepl" target="_blank" class="github-link">
						GitHub
					</a>
				</div>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<div class="container">
				<div class="landing-wordmark-wrap cursor-pointer" id="footer-wordmark" aria-label="AGREPL" role="img">
					<div class="landing-wordmark-letters">
						<span class="landing-wordmark-letter">A</span>
						<span class="landing-wordmark-letter">G</span>
						<span class="landing-wordmark-letter">R</span>
						<span class="landing-wordmark-letter">E</span>
						<span class="landing-wordmark-letter">P</span>
						<span class="landing-wordmark-letter">L</span>
					</div>
				</div>
				<div class="footer-content">
					<div class="footer-left">
						<div class="status-indicator">
							<span class="status-dot"></span>
							All systems operational
						</div>
						<p class="footer-copy">&copy; {new Date().getFullYear()} agrepl. MIT License.</p>
					</div>
					<div class="footer-right">
						<div class="footer-nav">
							<a href={`${import.meta.env.BASE_URL}/docs/introduction`}>Docs</a>
							<a href="https://github.com/taiwrash/agrepl" target="_blank">GitHub</a>
							<a href="#">Discord</a>
						</div>
						<span class="version-tag">v0.1.0-alpha</span>
					</div>
				</div>
			</div>
		</footer>

		<script>
			// Wordmark interaction (Dagryn-style staggered bounce)
			const wordmark = document.getElementById('footer-wordmark');
			const letters = wordmark.querySelectorAll('.landing-wordmark-letter');
			let isAnimating = false;

			async function triggerEasterEgg() {
				if (isAnimating) return;
				isAnimating = true;

				letters.forEach((letter, i) => {
					setTimeout(() => {
						letter.classList.add('bounce');
						setTimeout(() => {
							letter.classList.remove('bounce');
							if (i === letters.length - 1) isAnimating = false;
						}, 700);
					}, i * 70);
				});
			}

			wordmark.addEventListener('mouseenter', triggerEasterEgg);
			wordmark.addEventListener('click', triggerEasterEgg);
		</script>
	</body>
</html>
<style is:global>
	:root {
		--bg: #050505;
		--fg: #fafafa;
		--accent: #ffffff;
		--muted: #71717a;
		--surface: #09090b;
		--border: #27272a;
		--border-hover: #3f3f46;
	}
	* {
		box-sizing: border-box;
	}
	html {
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji';
		background: var(--bg);
		color: var(--fg);
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}
	body {
		margin: 0;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		position: relative;
		overflow-x: hidden;
	}
	.bg-glow {
		position: fixed;
		top: -20%;
		left: 50%;
		transform: translateX(-50%);
		width: 120vw;
		height: 100vh;
		background: radial-gradient(circle at center, rgba(255, 255, 255, 0.05) 0%, transparent 70%);
		pointer-events: none;
		z-index: -1;
	}
	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 1.5rem;
		width: 100%;
	}
	nav {
		padding: 1.5rem 0;
		background: rgba(5, 5, 5, 0.5);
		backdrop-filter: blur(20px);
		position: sticky;
		top: 0;
		z-index: 100;
		border-bottom: 1px solid var(--border);
	}
	nav .container {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.logo {
		font-size: 1.1rem;
		font-weight: 700;
		text-decoration: none;
		color: #fff;
		letter-spacing: -0.03em;
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}
	.logo-icon {
		width: 20px;
		height: 20px;
		background: #fff;
		border-radius: 0;
	}
	.links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}
	.links a {
		text-decoration: none;
		color: var(--muted);
		font-weight: 500;
		transition: color 0.2s;
		font-size: 0.9rem;
	}
	.links a:hover {
		color: #fff;
	}
	.github-link {
		padding: 0.4rem 0.8rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 0;
	}
	main {
		flex: 1;
	}
	
	/* Dagryn-style Footer */
	.site-footer {
		padding: 8rem 0 4rem;
		border-top: 1px solid var(--border);
		margin-top: 8rem;
		background: #000;
	}
	.landing-wordmark-wrap {
		display: flex;
		justify-content: center;
		margin-bottom: 6rem;
		cursor: pointer;
		user-select: none;
	}
	.landing-wordmark-letters {
		display: flex;
		gap: 0.5rem;
	}
	.landing-wordmark-letter {
		font-size: 12vw;
		font-weight: 900;
		color: #111;
		line-height: 1;
		transition: color 0.3s;
		display: inline-block;
		transform: skewX(-15deg); /* Slanted by default */
	}
	.landing-wordmark-wrap:hover .landing-wordmark-letter {
		color: #18181b;
	}
	.landing-wordmark-letter.bounce {
		animation: letterBounce 0.7s cubic-bezier(0.22, 1, 0.36, 1);
		color: #fff !important;
	}
	@keyframes letterBounce {
		0%, 100% { transform: translateY(0) skewX(-15deg) rotate(0) scale(1); }
		30% { transform: translateY(-32px) skewX(-15deg) rotate(-8deg) scale(1.1); }
		60% { transform: translateY(-12px) skewX(-15deg) rotate(4deg) scale(1.05); }
	}

	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		color: var(--muted);
		font-size: 0.85rem;
	}
	.footer-left {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.footer-right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 1.5rem;
	}
	.status-indicator {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: #52525b;
		font-weight: 500;
	}
	.status-dot {
		width: 6px;
		height: 6px;
		background: #3f3f46;
		border-radius: 50%;
	}
	.status-indicator:hover .status-dot {
		background: #fff;
		box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
	}
	.footer-nav {
		display: flex;
		gap: 2rem;
	}
	.footer-nav a {
		color: var(--muted);
		text-decoration: none;
		transition: color 0.2s;
	}
	.footer-nav a:hover {
		color: #fff;
	}
	.version-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		color: #3f3f46;
	}

	h1, h2, h3, h4 {
		color: #fff;
		letter-spacing: -0.02em;
	}
	a {
		color: #fff;
		transition: opacity 0.2s;
	}
	a:hover {
		opacity: 0.8;
	}
	pre {
		background: var(--surface) !important;
		padding: 1.25rem;
		border-radius: 0;
		border: 1px solid var(--border);
		overflow-x: auto;
		font-size: 0.85rem;
		line-height: 1.5;
	}
	code {
		font-family: 'JetBrains Mono', monospace;
	}
	::selection {
		background: #fff;
		color: #000;
	}

	@media (max-width: 768px) {
		.footer-content {
			flex-direction: column;
			align-items: center;
			gap: 3rem;
			text-align: center;
		}
		.footer-right {
			align-items: center;
		}
		.footer-wordmark-container .letter {
			font-size: 18vw;
		}
	}
</style>
