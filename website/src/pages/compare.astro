---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Compare - agrepl vs. The Orbit">
	<section class="compare-hero">
		<div class="container">
			<div class="badge">Strategic Comparison</div>
			<h1>agrepl vs. <span class="white-glow">The Orbit</span></h1>
			<p class="tagline">Observability is for watching. agrepl is for reproducing.</p>
		</div>
	</section>

	<section class="compare-matrix">
		<div class="container">
			<div class="matrix-wrapper">
				<table>
					<thead>
						<tr>
							<th>Feature</th>
							<th>Observability (LangSmith)</th>
							<th>Mocking (VCR.py)</th>
							<th class="highlight">agrepl</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td><strong>Primary Goal</strong></td>
							<td>Tracing & Evaluation</td>
							<td>HTTP Mocking</td>
							<td class="highlight">Deterministic Replay</td>
						</tr>
						<tr>
							<td><strong>Instrumentation</strong></td>
							<td>Requires SDK / Code changes</td>
							<td>Library-specific</td>
							<td class="highlight">Zero-instrumentation (CLI)</td>
						</tr>
						<tr>
							<td><strong>Network Logic</strong></td>
							<td>Passes through (Real calls)</td>
							<td>Stubs response</td>
							<td class="highlight">Frozen local state</td>
						</tr>
						<tr>
							<td><strong>Team Sync</strong></td>
							<td>Cloud Dashboard</td>
							<td>Manual file sharing</td>
							<td class="highlight">share → pull → replay</td>
						</tr>
						<tr>
							<td><strong>Determinism</strong></td>
							<td>Partial (logs only)</td>
							<td>High (for HTTP)</td>
							<td class="highlight">Strict (System-wide)</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<section class="deep-dive">
		<div class="container">
			<div class="comparison-grid-detailed">
				<!-- Observability -->
				<div class="compare-card-alt">
					<h3>vs. Observability (LangSmith, Helicone)</h3>
					<p>Observability tools are dashboards for what <em>happened</em>. They are great for analytics, but they don't let you re-live the execution. When an agent drifts, you need to see the exact raw response that caused the logic to fail.</p>
					<div class="verdict">
						<strong>The Pivot:</strong> agrepl is a debugger, not a dashboard.
					</div>
				</div>

				<!-- VCR -->
				<div class="compare-card-alt">
					<h3>vs. API Mocking (VCR.py, Polly.js)</h3>
					<p>API mocking was built for unit tests. Agents are more complex—they are multi-step, stateful, and non-deterministic. agrepl treats the entire execution as a single "run" that can be shared and replayed across machines.</p>
					<div class="verdict">
						<strong>The Pivot:</strong> agrepl captures the agent's journey, not just the API calls.
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="cta-final">
		<div class="container">
			<h2>Ready for a deterministic future?</h2>
			<a href={`${import.meta.env.BASE_URL}/docs/getting-started`} class="btn primary">Install CLI</a>
		</div>
	</section>
</Layout>

<style>
	.compare-hero {
		padding: 10rem 0 4rem;
		text-align: center;
	}
	.badge {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		margin-bottom: 2rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}
	h1 { font-size: 3.5rem; font-weight: 900; margin-bottom: 1.5rem; }
	.white-glow { text-shadow: 0 0 30px rgba(255,255,255,0.2); }
	.tagline { color: var(--muted); font-size: 1.25rem; max-width: 600px; margin: 0 auto; }

	.compare-matrix { padding: 6rem 0; }
	.matrix-wrapper {
		overflow-x: auto;
		border: 1px solid var(--border);
		background: rgba(255,255,255,0.01);
	}
	table {
		width: 100%;
		border-collapse: collapse;
		text-align: left;
	}
	th, td {
		padding: 1.5rem 2rem;
		border-bottom: 1px solid var(--border);
		font-size: 0.95rem;
	}
	th {
		background: rgba(255,255,255,0.03);
		color: var(--muted);
		font-weight: 600;
		text-transform: uppercase;
		font-size: 0.75rem;
		letter-spacing: 0.05em;
	}
	.highlight {
		background: rgba(255,255,255,0.04);
		font-weight: 600;
	}
	th.highlight { color: #fff; }

	.deep-dive { padding: 8rem 0; }
	.comparison-grid-detailed {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 3rem;
	}
	.compare-card-alt {
		padding: 3rem;
		border: 1px solid var(--border);
		background: var(--surface);
	}
	.compare-card-alt h3 { margin-bottom: 1.5rem; font-size: 1.4rem; }
	.compare-card-alt p { color: var(--muted); line-height: 1.6; margin-bottom: 2rem; }
	.verdict {
		padding: 1rem;
		background: rgba(255,255,255,0.03);
		border-left: 3px solid #fff;
		font-size: 0.9rem;
	}

	.cta-final {
		padding: 10rem 0;
		text-align: center;
		border-top: 1px solid var(--border);
	}
	.cta-final h2 { margin-bottom: 3rem; font-size: 2.5rem; }
	.btn.primary {
		padding: 1rem 3rem;
		background: #fff;
		color: #000;
		text-decoration: none;
		font-weight: 700;
	}

	@media (max-width: 800px) {
		.comparison-grid-detailed { grid-template-columns: 1fr; }
		h1 { font-size: 2.5rem; }
	}
</style>
