---
import Layout from '../layouts/Layout.astro';
---

<Layout title="agrepl - Debug AI agents with deterministic replay">
	<section class="hero">
		<div class="container">
			<div class="badge">Local-First, Privacy-Locked Open Source</div>
			<h1>Debug AI agents with <br/><span class="white-glow">deterministic replay</span></h1>
			<p class="tagline">Record LLM and API interactions. Replay them offline with zero network calls. Reproduce any agent run instantly.</p>
			
			<div class="value-bullets">
				<span>• Reproduce any agent run</span>
				<span>• Debug without hitting APIs</span>
				<span>• Works with any CLI tool (Python, Node, curl)</span>
			</div>

			<div class="ctas">
				<a href={`${import.meta.env.BASE_URL}/docs/getting-started`} class="btn primary">Get Started (30s)</a>
				<a href={`${import.meta.env.BASE_URL}/compare`} class="btn secondary">Compare</a>
				<a href={`${import.meta.env.BASE_URL}/pricing`} class="btn secondary">Pricing</a>
				<a href={`${import.meta.env.BASE_URL}/docs/introduction`} class="btn secondary">View Docs</a>
			</div>
		</div>
	</section>

	<section class="demo">
		<div class="container">
			<div class="terminal-perspective">
				<div class="glass-terminal" id="terminal">
					<div class="scanline"></div>
					<div class="terminal-header">
						<div class="dots">
							<span class="dot white"></span>
							<span class="dot white muted"></span>
							<span class="dot white muted"></span>
						</div>
						<div class="terminal-title">agrepl — deterministic replay</div>
						<button id="run-button" class="run-btn">
							<span class="play-icon"></span>
							Run Simulation
						</button>
					</div>
					<div class="terminal-body" id="terminal-body">
						<!-- Content populated by script -->
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="how-it-works">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">Replay, don't just observe.</h2>
				<p class="section-tagline">Three steps to deterministic debugging.</p>
			</div>
			
			<div class="flow-container">
				<div class="flow-line"></div>
				
				<div class="flow-step staggered">
					<div class="step-content">
						<div class="step-badge">Phase 01</div>
						<h4>Capture the behavior</h4>
						<p>Wrap any CLI command with <code>agrepl record</code>. It acts as a local bridge, intercepting LLM calls and tool interactions in real-time.</p>
						<div class="code-window">
							<div class="window-dot red"></div>
							<div class="window-dot yellow"></div>
							<div class="window-dot green"></div>
							<div class="code-content">agrepl record -- python agent.py</div>
						</div>
					</div>
					<div class="step-visual">
						<div class="pulse-circle"></div>
						<div class="pulse-ring"></div>
					</div>
				</div>

				<div class="flow-step staggered reverse">
					<div class="step-content">
						<div class="step-badge">Phase 02</div>
						<h4>Serve from the trace</h4>
						<p>Re-run instantly with <code>agrepl run</code>. Your agent thinks it's talking to the world, but it's actually pulling from a local, immutable JSON trace.</p>
						<div class="code-window">
							<div class="window-dot red"></div>
							<div class="window-dot yellow"></div>
							<div class="window-dot green"></div>
							<div class="code-content">agrepl run run-010</div>
						</div>
					</div>
					<div class="step-visual">
						<div class="lock-icon-visual">
							<div class="lock-shackle"></div>
							<div class="lock-body">
								<div class="lock-scanner"></div>
							</div>
						</div>
					</div>
				</div>

				<div class="flow-step staggered">
					<div class="step-content">
						<div class="step-badge">Phase 03</div>
						<h4>Debug offline</h4>
						<p>Fix code, tweak prompts, and re-test instantly. No network latency, no API costs, and 100% reproducibility.</p>
						<div class="status-indicator-alt">
							<span class="pulse-dot"></span>
							Network Isolated
						</div>
					</div>
					<div class="step-visual">
						<div class="offline-mesh">
							<span></span><span></span><span></span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="comparison-section">
		<div class="container">
			<div class="section-header">
				<h2 class="section-title">Beyond Observability.</h2>
				<p class="section-tagline">Stop watching bugs. Start reproducing them.</p>
			</div>

			<div class="comparison-grid">
				<div class="comparison-card">
					<div class="card-type">Traditional Observability</div>
					<ul>
						<li>
							<span class="cross">✕</span>
							<span>Observe what happened</span>
						</li>
						<li>
							<span class="cross">✕</span>
							<span>Requires SDK integration</span>
						</li>
						<li>
							<span class="cross">✕</span>
							<span>Cloud-first (SaaS)</span>
						</li>
						<li>
							<span class="cross">✕</span>
							<span>High API costs for replay</span>
						</li>
					</ul>
				</div>

				<div class="comparison-card highlighted">
					<div class="card-type">Deterministic agrepl</div>
					<ul>
						<li>
							<span class="check">✓</span>
							<span>Reproduce what happened</span>
						</li>
						<li>
							<span class="check">✓</span>
							<span>Zero-instrumentation</span>
						</li>
						<li>
							<span class="check">✓</span>
							<span>Local-first (Offline)</span>
						</li>
						<li>
							<span class="check">✓</span>
							<span>Zero API costs for replay</span>
						</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section class="use-cases">
		<div class="container">
			<h2 class="section-title small">Built for high-stakes agents</h2>
			<div class="bento-grid-creative">
				<div class="bento-card-glass spotlight">
					<div class="card-inner">
						<div class="icon-wrap">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
						</div>
						<h3>Burn code, <br/>not credits</h3>
						<p>Iterate on reasoning loops without hitting Gemini or OpenAI for every minor fix. Replay the same LLM response while you perfect your tool-calling logic.</p>
					</div>
					<div class="card-bg-gradient green"></div>
				</div>
				
				<div class="bento-card-glass spotlight">
					<div class="card-inner">
						<div class="icon-wrap">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/><path d="m9.05 14.57 2.12 2.12a2 2 0 0 0 2.83 0l4.24-4.24"/><path d="M7 10h.01"/><path d="M11 8h.01"/><path d="M15 10h.01"/></svg>
						</div>
						<h3>Kill the <br/>stochasticity</h3>
						<p>Stop chasing ghosts. When a test fails in CI, replay the exact run that broke. Determinism is the only way to build production-grade AI.</p>
					</div>
					<div class="card-bg-gradient blue"></div>
				</div>

				<div class="bento-card-glass spotlight">
					<div class="card-inner">
						<div class="icon-wrap">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>
						</div>
						<h3>Privacy-Locked <br/>by Default</h3>
						<p>Sensitive PII and proprietary prompts never leave your local environment. agrepl is a tool for developers who take security seriously.</p>
					</div>
					<div class="card-bg-gradient white"></div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<script>
	const script = [
		{
			command: "agrepl record -- python agent.py",
			output: [
				"[INFO] Proxy server listening on :8000",
				"[RECORD] Captured LLM: gemini-2.0-flash",
				"[RECORD] Captured HTTP: GET https://api.github.com/repos/google/agrepl",
				"[SUCCESS] 12 steps captured. Run ID: run-010"
			]
		},
		{
			command: "agrepl run run-010",
			output: [
				"[RUN] Shortcut for: agrepl replay run-010 --summary python agent.py",
				"[REPLAY] Mode: STRICT (no network allowed)",
				"[REPLAY] Matched LLM call: gemini-2.0-flash",
				"[REPLAY] Matched HTTP: GET https://api.github.com/repos/google/agrepl",
				"",
				"✓ Replay complete",
				"Steps: 12",
				"Network calls: 0",
				"Deterministic: yes"
			]
		}
	];

	const terminalBody = document.getElementById('terminal-body');
	const runButton = document.getElementById('run-button');
	let isRunning = false;

	async function typeLine(text, type = 'output', delay = 20) {
		const line = document.createElement('div');
		line.className = `line ${type}`;
		if (type === 'prompt') {
			line.innerHTML = `<span class="prompt">$</span> <span class="command-text"></span>`;
			terminalBody.appendChild(line);
			const commandSpan = line.querySelector('.command-text');
			for (let i = 0; i < text.length; i++) {
				commandSpan.textContent += text[i];
				await new Promise(r => setTimeout(r, delay));
			}
		} else {
			line.textContent = text;
			terminalBody.appendChild(line);
			await new Promise(r => setTimeout(r, delay * 2));
		}
		terminalBody.scrollTop = terminalBody.scrollHeight;
	}

	async function runSimulation() {
		if (isRunning) return;
		isRunning = true;
		runButton.disabled = true;
		runButton.classList.add('loading');
		terminalBody.innerHTML = '';

		for (const step of script) {
			await typeLine(step.command, 'prompt', 40);
			await new Promise(r => setTimeout(r, 400));
			for (const line of step.output) {
				let type = 'info';
				if (line.startsWith('[SUCCESS]')) type = 'success-text';
				if (line.startsWith('[RECORD]') || line.startsWith('[REPLAY]')) type = 'accent-text';
				await typeLine(line, type, 10);
			}
			await new Promise(r => setTimeout(r, 1000));
		}

		await typeLine('', 'prompt', 0);
		const finalLine = terminalBody.lastElementChild;
		finalLine.querySelector('.command-text').innerHTML = '<span class="cursor"></span>';
		
		isRunning = false;
		runButton.disabled = false;
		runButton.classList.remove('loading');
	}

	runButton.addEventListener('click', runSimulation);

	// Spotlight Effect
	document.querySelectorAll('.spotlight').forEach(card => {
		card.addEventListener('mousemove', e => {
			const rect = card.getBoundingClientRect();
			const x = e.clientX - rect.left;
			const y = e.clientY - rect.top;
			card.style.setProperty('--mouse-x', `${x}px`);
			card.style.setProperty('--mouse-y', `${y}px`);
		});
	});

	// Initial run
	window.addEventListener('load', () => {
		setTimeout(runSimulation, 1000);
	});
</script>

<style>
	.hero {
		padding: 10rem 0 4rem;
		text-align: center;
		position: relative;
	}
	.value-bullets {
		display: flex;
		gap: 2rem;
		justify-content: center;
		margin: 2rem 0 3rem;
		color: var(--muted);
		font-size: 0.9rem;
	}
	.badge {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 0;
		color: #fff;
		font-size: 0.8rem;
		font-weight: 600;
		margin-bottom: 2rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	h1 {
		font-size: clamp(2.5rem, 8vw, 4.5rem);
		font-weight: 900;
		line-height: 1.05;
		margin-bottom: 1.5rem;
		letter-spacing: -0.04em;
	}
	.white-glow {
		text-shadow: 0 0 30px rgba(255, 255, 255, 0.2);
	}
	.tagline {
		font-size: 1.25rem;
		color: var(--muted);
		max-width: 700px;
		margin: 0 auto;
		line-height: 1.5;
	}
	.ctas {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}
	.btn {
		padding: 0.8rem 2rem;
		border-radius: 0;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s;
		font-size: 0.95rem;
	}
	.btn.primary {
		background: #fff;
		color: #000;
	}
	.btn.primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 5px 15px rgba(255, 255, 255, 0.1);
	}
	.btn.secondary {
		background: var(--surface);
		color: #fff;
		border: 1px solid var(--border);
	}
	.btn.secondary:hover {
		border-color: var(--border-hover);
	}

	.demo {
		padding: 2rem 0 10rem;
	}
	.terminal-perspective {
		perspective: 1200px;
		width: 100%;
		max-width: 800px;
		margin: 0 auto;
	}
	.glass-terminal {
		background: rgba(10, 10, 10, 0.6);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 0;
		overflow: hidden;
		box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(12px);
		transform: rotateX(8deg) rotateY(-6deg);
		animation: float 6s ease-in-out infinite;
		position: relative;
		min-height: 380px;
	}
	@keyframes float {
		0%, 100% { transform: rotateX(8deg) rotateY(-6deg) translateY(0); }
		50% { transform: rotateX(10deg) rotateY(-8deg) translateY(-15px); }
	}

	.scanline {
		width: 100%;
		height: 100%;
		z-index: 10;
		background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
		background-size: 100% 2px, 3px 100%;
		position: absolute;
		top: 0; left: 0;
		pointer-events: none;
		opacity: 0.1;
	}

	.terminal-header {
		background: rgba(255, 255, 255, 0.03);
		padding: 1rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}
	.dots {
		display: flex;
		gap: 8px;
	}
	.dot {
		width: 10px;
		height: 10px;
		border-radius: 0;
		background: #fff;
	}
	.dot.muted { opacity: 0.15; }
	
	.terminal-title {
		font-size: 0.75rem;
		color: #555;
		font-family: 'JetBrains Mono', monospace;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}
	.run-btn {
		background: var(--surface);
		border: 1px solid var(--border);
		color: #fff;
		padding: 0.4rem 0.8rem;
		border-radius: 0;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		transition: all 0.2s;
	}
	.run-btn:hover:not(:disabled) {
		background: var(--border);
	}
	.play-icon {
		width: 0;
		height: 0;
		border-top: 4px solid transparent;
		border-bottom: 4px solid transparent;
		border-left: 6px solid #fff;
	}

	.terminal-body {
		padding: 2.5rem;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.9rem;
		line-height: 1.6;
		color: #a1a1aa;
	}
	.line { margin-bottom: 0.4rem; }
	.prompt {
		color: #fff;
		font-weight: 700;
		margin-right: 0.8rem;
	}
	.info { color: #52525b; }
	.success-text { color: #fff; font-weight: 600; }
	.accent-text { color: #d4d4d8; }
	.cursor {
		display: inline-block;
		width: 8px;
		height: 18px;
		background: #fff;
		vertical-align: middle;
		box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
		animation: blink 1s infinite;
	}
	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	.how-it-works {
		padding: 12rem 0;
		background: #000;
		position: relative;
		overflow: hidden;
	}
	.section-header {
		text-align: center;
		margin-bottom: 8rem;
	}
	.section-tagline {
		color: var(--muted);
		font-size: 1.1rem;
		margin-top: 1rem;
	}
	.flow-container {
		position: relative;
		max-width: 900px;
		margin: 0 auto;
	}
	.flow-line {
		position: absolute;
		top: 0; left: 50%;
		width: 1px; height: 100%;
		background: linear-gradient(to bottom, transparent, var(--border), var(--border), transparent);
		z-index: 0;
	}
	.flow-step {
		display: flex;
		align-items: center;
		gap: 6rem;
		margin-bottom: 10rem;
		position: relative;
		z-index: 1;
	}
	.flow-step.reverse {
		flex-direction: row-reverse;
	}
	.step-content {
		flex: 1;
	}
	.step-visual {
		flex: 1;
		display: flex;
		justify-content: center;
		align-items: center;
		position: relative;
	}
	.step-badge {
		display: inline-block;
		background: rgba(255, 255, 255, 0.05);
		padding: 0.3rem 0.8rem;
		border-radius: 0;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.7rem;
		color: #fff;
		margin-bottom: 1.5rem;
		border: 1px solid var(--border);
	}
	.step-content h4 {
		font-size: 1.8rem;
		font-weight: 800;
		margin-bottom: 1rem;
	}
	.step-content p {
		color: var(--muted);
		line-height: 1.7;
		font-size: 1rem;
		margin-bottom: 2rem;
	}
	.code-window {
		background: #050505;
		border: 1px solid var(--border);
		border-radius: 0;
		padding: 1.25rem;
		position: relative;
		box-shadow: 0 20px 40px rgba(0,0,0,0.6);
	}
	.window-dot {
		width: 8px; height: 8px;
		border-radius: 0;
		display: inline-block;
		margin-right: 4px;
		margin-bottom: 1rem;
	}
	.window-dot.red { background: #ff5f56; }
	.window-dot.yellow { background: #ffbd2e; }
	.window-dot.green { background: #27c93f; }
	.code-content {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8rem;
		color: #fff;
	}

	/* Visual Elements */
	.pulse-circle {
		width: 60px; height: 60px;
		background: #fff;
		border-radius: 0;
		box-shadow: 0 0 40px rgba(255, 255, 255, 0.2);
	}
	.pulse-ring {
		position: absolute;
		width: 100px; height: 100px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 50%;
		animation: ringPulse 2s infinite;
	}
	@keyframes ringPulse {
		0% { transform: scale(1); opacity: 0.5; }
		100% { transform: scale(2); opacity: 0; }
	}

	.lock-icon-visual {
		width: 80px; height: 100px;
		display: flex; flex-direction: column; align-items: center;
		position: relative;
	}
	.lock-body { 
		width: 60px; 
		height: 45px; 
		background: #18181b; 
		border: 1px solid var(--border);
		border-radius: 0; 
		position: relative;
		overflow: hidden;
		box-shadow: 0 0 20px rgba(255, 255, 255, 0.05);
	}
	.lock-scanner {
		position: absolute;
		top: -100%;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.1), transparent);
		animation: lockScan 2s infinite ease-in-out;
	}
	@keyframes lockScan {
		0% { top: -100%; }
		50% { top: 100%; }
		100% { top: 100%; }
	}
	.lock-shackle { 
		width: 32px; 
		height: 35px; 
		border: 4px solid #fff; 
		border-bottom: none; 
		border-radius: 16px 16px 0 0; 
		margin-bottom: -4px; 
		transition: transform 0.3s;
		animation: shackleLock 4s infinite ease-in-out;
	}
	@keyframes shackleLock {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(8px); }
	}

	.offline-mesh {
		display: flex; gap: 10px;
	}
	.offline-mesh span {
		width: 12px; height: 40px; background: #fff; border-radius: 0;
		animation: meshBounce 1.5s infinite ease-in-out;
	}
	.offline-mesh span:nth-child(2) { animation-delay: 0.2s; }
	.offline-mesh span:nth-child(3) { animation-delay: 0.4s; }
	@keyframes meshBounce {
		0%, 100% { height: 40px; opacity: 1; }
		50% { height: 20px; opacity: 0.3; }
	}

	.status-indicator-alt {
		display: flex; align-items: center; gap: 0.6rem;
		font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #fff;
	}
	.pulse-dot { border-radius: 50%; animation: blink 1s infinite; }

	/* Use Cases Creative */
	.bento-grid-creative {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin-top: 5rem;
	}
	.bento-card-glass {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border);
		border-radius: 0;
		padding: 3rem;
